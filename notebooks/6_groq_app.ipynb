    "from dotenv import load_dotenv\n",
    "load_dotenv()\n",
    "\n",
    "from langchain_groq import ChatGroq\n",
    "\n",
    "llm = ChatGroq(\n",
    "    model=\"groq/compound\"\n",
    ")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 4,
   "id": "813eac5d",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Below is a **single, self‑contained Python script** that demonstrates the core ideas behind a Graph Neural Network (GNN).  \n",
      "The code uses **PyTorch** and **PyTorch‑Geometric** (the most common library for building GNNs) and is heavily commented so that you can read the implementation and the underlying concepts at the same time.\n",
      "\n",
      "```python\n",
      "# --------------------------------------------------------------\n",
      "#  Graph Neural Network (GNN) – a minimal, end‑to‑end example\n",
      "# --------------------------------------------------------------\n",
      "# What this script shows:\n",
      "#   1️⃣ How a graph is represented (node features + edge list)\n",
      "#   2️⃣ The *message‑passing* step performed by a GCN layer\n",
      "#   3️⃣ How node embeddings are updated and can be used downstream\n",
      "#\n",
      "# Requirements (install before running):\n",
      "#   pip install torch\n",
      "#   pip install torch-scatter -f https://data.pyg.org/whl/torch-2.2.0+cpu.html\n",
      "#   pip install torch-sparse  -f https://data.pyg.org/whl/torch-2.2.0+cpu.html\n",
      "#   pip install torch-geometric\n",
      "#\n",
      "# --------------------------------------------------------------\n",
      "\n",
      "import torch\n",
      "import torch.nn as nn\n",
      "import torch.nn.functional as F\n",
      "from torch_geometric.data import Data          # basic graph container\n",
      "from torch_geometric.nn import GCNConv         # Graph Convolutional layer\n",
      "\n",
      "# ------------------------------------------------------------------\n",
      "# 1️⃣  Graph definition\n",
      "# ------------------------------------------------------------------\n",
      "#   • 4 nodes, each with a 10‑dimensional feature vector (randomly init.)\n",
      "#   • Undirected edges: (0‑1), (1‑2), (2‑3), (3‑0)\n",
      "#   • In PyTorch‑Geometric edges are stored as a 2×E tensor\n",
      "# ------------------------------------------------------------------\n",
      "num_nodes = 4\n",
      "node_feat_dim = 10\n",
      "\n",
      "x = torch.randn(num_nodes, node_feat_dim)               # node feature matrix (N×F)\n",
      "edge_index = torch.tensor([[0, 1, 1, 2, 2, 3, 3, 0],\n",
      "                           [1, 0, 2, 1, 3, 2, 0, 3]], dtype=torch.long)\n",
      "# The above creates two directed edges for each undirected connection.\n",
      "\n",
      "# Wrap everything in a PyG `Data` object (convenient container)\n",
      "data = Data(x=x, edge_index=edge_index)\n",
      "\n",
      "# ------------------------------------------------------------------\n",
      "# 2️⃣  GNN model definition (2‑layer Graph Convolutional Network)\n",
      "# ------------------------------------------------------------------\n",
      "class SimpleGCN(nn.Module):\n",
      "    \"\"\"\n",
      "    A minimal GCN with two convolutional layers:\n",
      "        - conv1 : 10 → 16   (learns a hidden representation)\n",
      "        - conv2 : 16 → 7    (produces final node embeddings)\n",
      "    The forward pass performs the classic *message‑passing*:\n",
      "        1. Each node gathers (sums) transformed features from its neighbours.\n",
      "        2. A non‑linear activation (ReLU) is applied.\n",
      "        3. Optional dropout for regularisation.\n",
      "        4. A second aggregation produces the output embeddings.\n",
      "    \"\"\"\n",
      "    def __init__(self):\n",
      "        super().__init__()\n",
      "        self.conv1 = GCNConv(in_channels=node_feat_dim, out_channels=16)\n",
      "        self.conv2 = GCNConv(in_channels=16, out_channels=7)\n",
      "\n",
      "    def forward(self, data):\n",
      "        x, edge_index = data.x, data.edge_index\n",
      "\n",
      "        # ---- Message passing layer 1 ----\n",
      "        x = self.conv1(x, edge_index)          # aggregate neighbour info\n",
      "        x = F.relu(x)                          # non‑linear update\n",
      "        x = F.dropout(x, p=0.5, training=self.training)\n",
      "\n",
      "        # ---- Message passing layer 2 ----\n",
      "        x = self.conv2(x, edge_index)          # second aggregation\n",
      "        return x                               # final node embeddings (N×7)\n",
      "\n",
      "# ------------------------------------------------------------------\n",
      "# 3️⃣  Training loop (toy example)\n",
      "# ------------------------------------------------------------------\n",
      "model = SimpleGCN()\n",
      "optimizer = torch.optim.Adam(model.parameters(), lr=0.01)\n",
      "\n",
      "# For illustration we create a dummy target (e.g. node‑level regression)\n",
      "target = torch.randn(num_nodes, 7)   # shape must match model output\n",
      "\n",
      "for epoch in range(1, 101):\n",
      "    model.train()\n",
      "    optimizer.zero_grad()\n",
      "\n",
      "    out = model(data)                 # forward pass → node embeddings\n",
      "    loss = F.mse_loss(out, target)    # simple L2 loss (just for demo)\n",
      "    loss.backward()\n",
      "    optimizer.step()\n",
      "\n",
      "    if epoch % 20 == 0:\n",
      "        print(f'Epoch {epoch:3d} | Loss: {loss.item():.4f}')\n",
      "\n",
      "# ------------------------------------------------------------------\n",
      "# 4️⃣  What have we learned?\n",
      "# ------------------------------------------------------------------\n",
      "# • The graph is encoded by `edge_index` (connectivity) and `x` (features).\n",
      "# • Each GCN layer implements *message passing*: a node receives a\n",
      "#   weighted sum of its neighbours' features, normalised by node degree.\n",
      "# • After a few layers, a node's representation contains information\n",
      "#   from its multi‑hop neighbourhood – the essence of GNNs.\n",
      "# • The final embeddings (`out`) can be fed to downstream tasks:\n",
      "#   node classification, link prediction, graph classification, etc.\n",
      "# --------------------------------------------------------------\n",
      "```\n",
      "\n",
      "### Quick walk‑through of the concepts\n",
      "\n",
      "| Concept | How it appears in the script |\n",
      "|---------|------------------------------|\n",
      "| **Graph representation** | `x` (node feature matrix) and `edge_index` (edge list) stored in a `torch_geometric.data.Data` object. |\n",
      "| **Message passing** | Each `GCNConv` layer performs `aggregate → combine → update`. The aggregation step gathers neighbour features, the combine step applies a learnable linear transformation, and the update step adds a non‑linearity (ReLU). |\n",
      "| **Node update / embedding** | After the first layer, node features become 16‑dimensional; after the second, they become 7‑dimensional. These vectors now encode information from the node’s local graph structure. |\n",
      "| **Training** | A tiny supervised loop (MSE loss) shows how the model parameters are learned end‑to‑end, exactly like any other neural network. |\n",
      "| **Usage** | The resulting node embeddings (`out`) can be used for any downstream graph‑structured task (classification, regression, clustering, etc.). |\n",
      "\n",
      "**Takeaway:** A GNN repeatedly applies the *message‑passing* operation across the graph, allowing each node to iteratively absorb information from its neighbours. The compact code above captures that whole pipeline in a single, easy‑to‑read script.\n"
     ]
    }
   ],
   "source": [
    "res = llm.invoke(\"in a single python code explain me the concept of graph neural networks\")\n",
    "print(res.content)"
   ]
